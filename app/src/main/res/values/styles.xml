<?xml version="1.0" encoding="utf-8" standalone="no"?>
<resources>

    <style name="Theme.SumiShisen.Card" parent="Base.Widget.Material3.CardView">
        <item name="cardBackgroundColor">@color/md_theme_surface</item>
        <item name="strokeWidth">0dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Large</item>
    </style>

    <style name="Theme.SumiShisen.Button.Large" parent="Widget.Material3.Button">
        <item name="background">@drawable/selector_button</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/md_theme_onPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:elegantTextHeight">true</item>
    </style>

    <style name="Theme.SumiShisen.Button.Function" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/md_theme_primary</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:textColor">@color/md_theme_onPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:autoSizeMinTextSize">14sp</item>
        <item name="android:autoSizeMaxTextSize">18sp</item>
        <item name="android:autoSizeTextType">uniform</item>
        <item name="android:elegantTextHeight">true</item>
    </style>

    <style name="Theme.SumiShisen.Button.Input" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/md_theme_secondary</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/md_theme_onSecondary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:elegantTextHeight">true</item>
    </style>

    <style name="Theme.SumiShisen.Switch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="materialThemeOverlay">@style/ThemeOverlay.App.Switch</item>
    </style>

    <style name="ThemeOverlay.App.Switch" parent="">
        <item name="colorPrimary">@color/md_theme_primary</item>
        <item name="colorSurfaceVariant">@color/md_theme_surfaceVariant</item>
    </style>
</resources>